# ==================== OPTIONAL (uncomment to override defaults) ====================
# OCPU=4                # CPU cores (default: 4, max: 4 for free tier)
# MEMORY=24             # RAM in GB (default: 24, max: 24 for free tier)
# BOOT_VOLUME=100        # Disk size in GB (default: 100)
# PROFILE="DEFAULT"     # OCI CLI profile name (default: DEFAULT)
# MAX_RETRIES=1000      # Max attempts (default: 1000, set 0 for infinite)

# ==================== TELEGRAM MONITORING (optional) ====================
# Uncomment and fill these to enable Telegram notifications.
# Get a bot token from @BotFather on Telegram.
# Get your Chat ID by messaging @userinfobot on Telegram.
#
# TELEGRAM_ENABLED=true           # Set to "true" to activate notifications
# TELEGRAM_TOKEN="your-bot-token-here"
# TELEGRAM_CHAT_ID="your-chat-id-here"
# TELEGRAM_NOTIFY_INTERVAL=100    # Send status update every N attempts (0 = disable interval updates)
#
# ==================== SSH KEY BACKUP VIA TELEGRAM (optional) ====================
# Requires: TELEGRAM_ENABLED=true AND gpg installed on the system.
# The private key will be encrypted with GPG before being sent.
# NEVER share the GPG_PASSWORD; it is needed to decrypt the backup.
#
# TELEGRAM_SEND_KEY=true          # Set to "true" to send encrypted SSH key on script start
# GPG_PASSWORD="your-strong-passphrase-here"  # Passphrase used to encrypt the SSH key