# Go to Profile -> Tenancy (Tenancy information OCID) and copy it here
TENANCY_ID="ocid1.tenancy.oc1..***"
# Check README.md step 7
IMAGE_ID="ocid1.image.oc1.***.***"
# Check README.md step 8
SUBNET_ID="ocid1.subnet.oc1.***.***"
# Check README.md step 9
AVAILABILITY_DOMAIN="JtDP:***"
# Check README.md step 10
PATH_TO_PUBLIC_SSH_KEY="$HOME/.ssh/your-oracle-arm-ssh.key.pub"

# ==================== OPTIONAL (uncomment to override defaults) ====================
# OCPU=4                # CPU cores (default: 4, max: 4 for free tier)
# MEMORY=24             # RAM in GB (default: 24, max: 24 for free tier)
# BOOT_VOLUME=50        # Disk size in GB (default: 50)
# PROFILE="DEFAULT"     # OCI CLI profile name (default: DEFAULT)
# MAX_RETRIES=1000      # Max attempts (default: 1000, set 0 for infinite)